{
  "manifest_version": 3,
  "name": "id4pii guard",
  "version": "0.1.0",
  "description": "Local PII anonymization for ChatGPT, Claude, and Gemini. Swaps real names and emails for stand-ins before the request goes out.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.openai.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["logger.js", "ui.js", "content.js"],
      "world": "ISOLATED",
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.openai.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["logger_main.js", "main_world.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "id4pii guard",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/lock_frames/*", "assets/icon-*.png"],
      "matches": [
        "*://chatgpt.com/*",
        "*://*.openai.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*"
      ]
    }
  ]
}
